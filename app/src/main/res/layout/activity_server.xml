<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/terminal_bg">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/surface_dark"
            app:titleTextColor="@color/accent_blue"/>
    </com.google.android.material.appbar.AppBarLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Port:"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:layout_marginEnd="8dp"/>
        <EditText
            android:id="@+id/etPort"
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            android:text="8080"
            android:inputType="number"
            android:textColor="@color/terminal_text"
            android:fontFamily="monospace"/>
        <Button
            android:id="@+id/btnStartStop"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="Start Server"
            android:backgroundTint="@color/accent_green"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🔴 Server stopped"
        android:textColor="@color/accent_blue"
        android:fontFamily="monospace"
        android:textSize="13sp"
        android:padding="16dp"
        android:background="@color/surface_dark"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="REQUEST LOG"
        android:textColor="@color/text_secondary"
        android:fontFamily="monospace"
        android:textSize="11sp"
        android:padding="8dp"
        android:letterSpacing="0.1"/>

    <ScrollView
        android:id="@+id/scrollLog"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp">
        <TextView
            android:id="@+id/tvLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="(server not running)"
            android:textColor="@color/text_secondary"
            android:fontFamily="monospace"
            android:textSize="12sp"/>
    </ScrollView>
</LinearLayout>
