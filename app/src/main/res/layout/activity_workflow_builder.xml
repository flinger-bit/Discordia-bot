<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/terminal_bg">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/surface_dark"
            app:titleTextColor="@color/accent_purple"/>
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- GitHub Credentials Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GITHUB CREDENTIALS"
                android:textColor="@color/text_secondary"
                android:fontFamily="monospace"
                android:textSize="10sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="6dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/surface_dark"
                app:cardCornerRadius="8dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <EditText
                        android:id="@+id/etToken"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="GitHub Personal Access Token (repo + actions scope)"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary"
                        android:fontFamily="monospace"
                        android:textSize="12sp"
                        android:inputType="textPassword"
                        android:background="@null"
                        android:paddingBottom="4dp"/>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/surface_medium" android:layout_marginVertical="6dp"/>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <EditText
                            android:id="@+id/etOwner"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="github-username"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_secondary"
                            android:fontFamily="monospace"
                            android:textSize="12sp"
                            android:background="@null"
                            android:inputType="text"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text=" / " android:textColor="@color/text_secondary" android:textSize="14sp"/>
                        <EditText
                            android:id="@+id/etRepo"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="repo-name"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_secondary"
                            android:fontFamily="monospace"
                            android:textSize="12sp"
                            android:background="@null"
                            android:inputType="text"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginTop="8dp">
                        <Button
                            android:id="@+id/btnSaveCredentials"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1"
                            android:text="Save &amp; Verify"
                            android:textSize="12sp"
                            android:backgroundTint="@color/accent_blue"
                            android:layout_marginEnd="6dp"/>
                        <Button
                            android:id="@+id/btnNewRepo"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1"
                            android:text="+ New Repo"
                            android:textSize="12sp"
                            android:backgroundTint="@color/accent_green"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Template Picker -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BUILD TEMPLATE"
                android:textColor="@color/text_secondary"
                android:fontFamily="monospace"
                android:textSize="10sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="6dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/surface_dark"
                app:cardCornerRadius="8dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="12dp">
                    <Spinner
                        android:id="@+id/spinnerTemplate"
                        android:layout_width="match_parent"
                        android:layout_height="42dp"
                        android:backgroundTint="@color/accent_purple"
                        android:paddingStart="4dp"/>
                    <TextView
                        android:id="@+id/tvDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Select a template above"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:layout_marginTop="6dp"
                        android:fontFamily="monospace"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Workflow Name + YAML editor -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="WORKFLOW YAML"
                android:textColor="@color/text_secondary"
                android:fontFamily="monospace"
                android:textSize="10sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="6dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/surface_dark"
                app:cardCornerRadius="8dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="12dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text=".github/workflows/" android:textColor="@color/text_secondary"
                            android:fontFamily="monospace" android:textSize="12sp"/>
                        <EditText
                            android:id="@+id/etWorkflowName"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="build.yml"
                            android:textColor="@color/accent_green"
                            android:fontFamily="monospace"
                            android:textSize="12sp"
                            android:background="@null"
                            android:inputType="text"/>
                    </LinearLayout>
                    <EditText
                        android:id="@+id/tvYaml"
                        android:layout_width="match_parent"
                        android:layout_height="320dp"
                        android:gravity="top|start"
                        android:textColor="@color/terminal_text"
                        android:textSize="11sp"
                        android:background="@color/terminal_bg"
                        android:padding="8dp"
                        android:inputType="textMultiLine"
                        android:scrollbars="vertical"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Action buttons -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="8dp">
                <Button
                    android:id="@+id/btnPushAndBuild"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="2"
                    android:text="🚀 Push &amp; Build"
                    android:backgroundTint="@color/accent_purple"
                    android:layout_marginEnd="6dp"/>
                <Button
                    android:id="@+id/btnSaveLocal"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="💾 Save"
                    android:backgroundTint="@color/surface_medium"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="12dp">
                <Button
                    android:id="@+id/btnCheckStatus"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="🔄 Status"
                    android:textSize="12sp"
                    android:backgroundTint="@color/accent_blue"
                    android:layout_marginEnd="6dp"/>
                <Button
                    android:id="@+id/btnDownloadArtifacts"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="⬇ Download"
                    android:textSize="12sp"
                    android:backgroundTint="@color/accent_green"
                    android:enabled="false"/>
            </LinearLayout>

            <!-- Status output -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BUILD STATUS"
                android:textColor="@color/text_secondary"
                android:fontFamily="monospace"
                android:textSize="10sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="6dp"/>

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:indeterminateTint="@color/accent_purple"/>

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Enter credentials and select a template to get started.\nArtifacts are saved to /sdcard/DiscordiaBuilds/"
                android:textColor="@color/terminal_text"
                android:fontFamily="monospace"
                android:textSize="12sp"
                android:padding="12dp"
                android:background="@color/surface_dark"
                android:textIsSelectable="true"
                android:layout_marginBottom="24dp"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
