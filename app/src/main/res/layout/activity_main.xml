<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/terminal_bg">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/surface_dark"
            app:titleTextColor="@color/accent_purple"
            app:title="DISCORDIA TERMINAL"/>
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Header -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="SM-X200 · Android 14 · Offline-first toolkit"
                android:textColor="@color/text_secondary"
                android:fontFamily="monospace"
                android:textSize="11sp"
                android:gravity="center"
                android:layout_marginBottom="20dp"/>

            <!-- Row 0: IDE (full width) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardIde"
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="#1f2d3d"
                app:cardCornerRadius="12dp"
                app:cardElevation="6dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                    android:orientation="horizontal" android:gravity="center_vertical" android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="⚡" android:textSize="40sp" android:layout_marginEnd="14dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="VS CODE IDE" android:textColor="@color/accent_blue"
                            android:fontFamily="monospace" android:textSize="16sp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Monaco Editor • Syntax Highlight • Git • Multi-tab • Terminal • IntelliSense"
                            android:textColor="@color/text_secondary" android:fontFamily="monospace" android:textSize="10sp"/>
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="▶" android:textColor="@color/accent_blue" android:textSize="20sp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Row 1: Terminal + Git -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardTerminal"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardBackgroundColor="@color/surface_dark"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="vertical" android:gravity="center" android:padding="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="⌨" android:textSize="32sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="TERMINAL" android:textColor="@color/accent_green"
                            android:fontFamily="monospace" android:textSize="13sp"
                            android:layout_marginTop="6dp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Shell • 30+ commands" android:textColor="@color/text_secondary"
                            android:fontFamily="monospace" android:textSize="10sp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardGit"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    app:cardBackgroundColor="@color/surface_dark"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="vertical" android:gravity="center" android:padding="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="⎇" android:textSize="32sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="GIT / SCM" android:textColor="@color/accent_orange"
                            android:fontFamily="monospace" android:textSize="13sp"
                            android:layout_marginTop="6dp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Commit • Push • Diff" android:textColor="@color/text_secondary"
                            android:fontFamily="monospace" android:textSize="10sp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- Row 2: Files + Server -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardFiles"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardBackgroundColor="@color/surface_dark"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="vertical" android:gravity="center" android:padding="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="📁" android:textSize="32sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="FILE MANAGER" android:textColor="@color/accent_blue"
                            android:fontFamily="monospace" android:textSize="12sp"
                            android:layout_marginTop="6dp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Browse • Edit • Share" android:textColor="@color/text_secondary"
                            android:fontFamily="monospace" android:textSize="10sp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardServer"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    app:cardBackgroundColor="@color/surface_dark"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="vertical" android:gravity="center" android:padding="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🌐" android:textSize="32sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="LOCAL SERVER" android:textColor="@color/accent_orange"
                            android:fontFamily="monospace" android:textSize="12sp"
                            android:layout_marginTop="6dp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="HTTP • WiFi • LAN" android:textColor="@color/text_secondary"
                            android:fontFamily="monospace" android:textSize="10sp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- Row 3: Mods + Setup -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardMods"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardBackgroundColor="@color/surface_dark"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="vertical" android:gravity="center" android:padding="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="⚗️" android:textSize="32sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="MOD BUILDER" android:textColor="@color/accent_red"
                            android:fontFamily="monospace" android:textSize="12sp"
                            android:layout_marginTop="6dp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Java • Bedrock • Addons" android:textColor="@color/text_secondary"
                            android:fontFamily="monospace" android:textSize="10sp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardSetup"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    app:cardBackgroundColor="@color/surface_dark"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="vertical" android:gravity="center" android:padding="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="📂" android:textSize="32sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="SETUP FOLDER" android:textColor="@color/accent_cyan"
                            android:fontFamily="monospace" android:textSize="12sp"
                            android:layout_marginTop="6dp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Scripts • Run • Automate" android:textColor="@color/text_secondary"
                            android:fontFamily="monospace" android:textSize="10sp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- Row 4: Workflows + Extensions + Settings -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardWorkflows"
                    android:layout_width="0dp"
                    android:layout_height="110dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    app:cardBackgroundColor="@color/surface_dark"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="vertical" android:gravity="center" android:padding="10dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🚀" android:textSize="28sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="WORKFLOWS" android:textColor="@color/accent_purple"
                            android:fontFamily="monospace" android:textSize="11sp"
                            android:layout_marginTop="4dp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Build • CI/CD" android:textColor="@color/text_secondary"
                            android:fontFamily="monospace" android:textSize="9sp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardExtensions"
                    android:layout_width="0dp"
                    android:layout_height="110dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    app:cardBackgroundColor="@color/surface_dark"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="vertical" android:gravity="center" android:padding="10dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🧩" android:textSize="28sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="EXTENSIONS" android:textColor="@color/accent_pink"
                            android:fontFamily="monospace" android:textSize="11sp"
                            android:layout_marginTop="4dp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="28+ plugins" android:textColor="@color/text_secondary"
                            android:fontFamily="monospace" android:textSize="9sp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardSettings"
                    android:layout_width="0dp"
                    android:layout_height="110dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="@color/surface_dark"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:orientation="vertical" android:gravity="center" android:padding="10dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="⚙" android:textSize="28sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="SETTINGS" android:textColor="@color/accent_yellow"
                            android:fontFamily="monospace" android:textSize="11sp"
                            android:layout_marginTop="4dp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Themes • GitHub" android:textColor="@color/text_secondary"
                            android:fontFamily="monospace" android:textSize="9sp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- Footer -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Discordia Terminal v2.0 — VS Code Edition — SM-X200 · Android 14"
                android:textColor="@color/text_secondary"
                android:fontFamily="monospace"
                android:textSize="9sp"
                android:gravity="center"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
