<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.DiscordiaTerminal" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/accent_blue</item>
        <item name="colorPrimaryVariant">@color/surface_dark</item>
        <item name="colorOnPrimary">@color/terminal_bg</item>
        <item name="colorSecondary">@color/accent_green</item>
        <item name="colorOnSecondary">@color/terminal_bg</item>
        <item name="android:colorBackground">@color/terminal_bg</item>
        <item name="android:windowBackground">@color/terminal_bg</item>
        <item name="android:statusBarColor">@color/surface_dark</item>
        <item name="android:navigationBarColor">@color/surface_dark</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.DiscordiaTerminal.Terminal" parent="Theme.DiscordiaTerminal">
        <item name="android:colorBackground">@color/terminal_bg</item>
    </style>

    <style name="Theme.DiscordiaTerminal.Splash" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/terminal_bg</item>
        <item name="android:statusBarColor">@color/terminal_bg</item>
        <item name="android:navigationBarColor">@color/terminal_bg</item>
    </style>

    <style name="QuickButton" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:textColor">@color/accent_green</item>
        <item name="android:textSize">11sp</item>
        <item name="android:paddingStart">8dp</item>
        <item name="android:paddingEnd">8dp</item>
        <item name="android:minWidth">0dp</item>
    </style>
</resources>
