<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:background="@color/terminal_bg">

    <TextView android:id="@+id/tvExtIcon"
        android:layout_width="44dp" android:layout_height="44dp"
        android:textSize="24sp" android:gravity="center"
        android:background="@color/surface_dark"
        android:layout_marginEnd="12dp"/>

    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="8dp">
        <TextView android:id="@+id/tvExtName"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="@color/text_primary" android:textSize="13sp" android:textStyle="bold"/>
        <TextView android:id="@+id/tvExtDesc"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textColor="@color/text_secondary" android:textSize="11sp"
            android:layout_marginTop="2dp" android:maxLines="2"/>
        <TextView android:id="@+id/tvExtMeta"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="@color/text_secondary" android:textSize="10sp"
            android:layout_marginTop="3dp"/>
    </LinearLayout>

    <Button android:id="@+id/btnExtAction"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:textSize="11sp" android:paddingStart="10dp" android:paddingEnd="10dp"
        android:layout_gravity="center_vertical"/>

</LinearLayout>
