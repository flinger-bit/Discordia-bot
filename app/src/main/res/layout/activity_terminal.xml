<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/terminal_bg">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/surface_dark"
            app:titleTextColor="@color/accent_green"/>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- Quick key row 1: Control keys -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#0f1720"
        android:scrollbars="none">
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:orientation="horizontal"
            android:paddingStart="2dp"
            android:paddingEnd="2dp">
            <Button android:id="@+id/btnCtrlC" style="@style/QuickButton" android:text="Ctrl+C"/>
            <Button android:id="@+id/btnCtrlD" style="@style/QuickButton" android:text="Ctrl+D"/>
            <Button android:id="@+id/btnCtrlZ" style="@style/QuickButton" android:text="Ctrl+Z"/>
            <Button android:id="@+id/btnTab" style="@style/QuickButton" android:text="Tab"/>
            <Button android:id="@+id/btnEsc" style="@style/QuickButton" android:text="Esc"/>
            <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#30363d" android:layout_marginStart="2dp" android:layout_marginEnd="2dp"/>
            <Button android:id="@+id/btnArrowUp" style="@style/QuickButton" android:text="▲"/>
            <Button android:id="@+id/btnArrowDown" style="@style/QuickButton" android:text="▼"/>
            <Button android:id="@+id/btnArrowLeft" style="@style/QuickButton" android:text="◀"/>
            <Button android:id="@+id/btnArrowRight" style="@style/QuickButton" android:text="▶"/>
            <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#30363d" android:layout_marginStart="2dp" android:layout_marginEnd="2dp"/>
            <Button android:id="@+id/btnHome" style="@style/QuickButton" android:text="Home"/>
            <Button android:id="@+id/btnEnd" style="@style/QuickButton" android:text="End"/>
            <Button android:id="@+id/btnPgUp" style="@style/QuickButton" android:text="PgUp"/>
            <Button android:id="@+id/btnPgDn" style="@style/QuickButton" android:text="PgDn"/>
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Quick key row 2: Special chars -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#0d1117"
        android:scrollbars="none">
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:orientation="horizontal"
            android:paddingStart="2dp"
            android:paddingEnd="2dp">
            <Button android:id="@+id/btnPipe" style="@style/QuickButton" android:text="|"/>
            <Button android:id="@+id/btnAmp" style="@style/QuickButton" android:text="&amp;"/>
            <Button android:id="@+id/btnSlash" style="@style/QuickButton" android:text="/"/>
            <Button android:id="@+id/btnBackslash" style="@style/QuickButton" android:text="\\"/>
            <Button android:id="@+id/btnTilde" style="@style/QuickButton" android:text="~"/>
            <Button android:id="@+id/btnDash" style="@style/QuickButton" android:text="-"/>
            <Button android:id="@+id/btnUnderscore" style="@style/QuickButton" android:text="_"/>
            <Button android:id="@+id/btnDot" style="@style/QuickButton" android:text="."/>
            <Button android:id="@+id/btnStar" style="@style/QuickButton" android:text="*"/>
            <Button android:id="@+id/btnDollar" style="@style/QuickButton" android:text="$"/>
            <Button android:id="@+id/btnAt" style="@style/QuickButton" android:text="@"/>
            <Button android:id="@+id/btnHash" style="@style/QuickButton" android:text="#"/>
            <Button android:id="@+id/btnQuote" style="@style/QuickButton" android:text="&quot;"/>
            <Button android:id="@+id/btnSingleQuote" style="@style/QuickButton" android:text="'"/>
            <Button android:id="@+id/btnGt" style="@style/QuickButton" android:text="&gt;"/>
            <Button android:id="@+id/btnLt" style="@style/QuickButton" android:text="&lt;"/>
            <Button android:id="@+id/btnSemicolon" style="@style/QuickButton" android:text=";"/>
            <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#30363d" android:layout_marginStart="2dp" android:layout_marginEnd="2dp"/>
            <Button android:id="@+id/btnClear" style="@style/QuickButton" android:text="Clear" android:textColor="#f85149"/>
            <Button android:id="@+id/btnCopy" style="@style/QuickButton" android:text="Copy"/>
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Terminal output -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:padding="8dp">
        <TextView
            android:id="@+id/tvOutput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/terminal_text"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:lineSpacingExtra="3dp"
            android:textIsSelectable="true"/>
    </ScrollView>

    <!-- Input row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/surface_dark"
        android:padding="4dp">

        <TextView
            android:id="@+id/tvPrompt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/accent_green"
            android:fontFamily="monospace"
            android:textSize="12sp"
            android:paddingStart="4dp"
            android:paddingBottom="2dp"
            android:text="discordia@SM-X200:~$"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <EditText
                android:id="@+id/etInput"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Enter command..."
                android:textColor="@color/terminal_text"
                android:textColorHint="@color/text_secondary"
                android:fontFamily="monospace"
                android:textSize="13sp"
                android:background="@null"
                android:imeOptions="actionDone"
                android:inputType="text|textNoSuggestions"
                android:maxLines="1"
                android:paddingStart="4dp"/>
            <Button
                android:id="@+id/btnExec"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EXEC"
                android:textColor="@color/terminal_bg"
                android:backgroundTint="@color/accent_green"
                android:textSize="11sp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
