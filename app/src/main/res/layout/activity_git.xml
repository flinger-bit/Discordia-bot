<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/terminal_bg">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/surface_dark"
            app:titleTextColor="@color/accent_blue"/>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- Branch + status -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/surface_dark"
        android:padding="10dp"
        android:layout_marginBottom="2dp">
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
            <TextView android:id="@+id/tvBranch" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="@color/accent_blue" android:fontFamily="monospace" android:textSize="13sp" android:text="Branch: main"/>
            <TextView android:id="@+id/tvStatus" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="@color/text_secondary" android:fontFamily="monospace" android:textSize="11sp" android:text="Loading..."/>
        </LinearLayout>
        <Button android:id="@+id/btnOpenIde" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="IDE" android:textSize="11sp" android:backgroundTint="@color/accent_purple"
            android:textColor="@color/terminal_bg" android:paddingStart="10dp" android:paddingEnd="10dp"/>
    </LinearLayout>

    <!-- Action buttons row 1 -->
    <HorizontalScrollView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="@color/surface_dark" android:scrollbars="none" android:layout_marginBottom="2dp">
        <LinearLayout android:layout_width="wrap_content" android:layout_height="44dp"
            android:orientation="horizontal" android:padding="4dp" android:gravity="center_vertical">
            <Button android:id="@+id/btnRefresh" style="@style/QuickButton" android:text="↻ Refresh"/>
            <Button android:id="@+id/btnLog" style="@style/QuickButton" android:text="📋 Log"/>
            <Button android:id="@+id/btnDiff" style="@style/QuickButton" android:text="⟷ Diff"/>
            <Button android:id="@+id/btnBranches" style="@style/QuickButton" android:text="⎇ Branches"/>
            <Button android:id="@+id/btnInit" style="@style/QuickButton" android:text="⚡ Init"/>
            <Button android:id="@+id/btnClone" style="@style/QuickButton" android:text="⬇ Clone"/>
            <Button android:id="@+id/btnCopy" style="@style/QuickButton" android:text="📋 Copy"/>
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Stage/Unstage row -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:background="@color/surface_dark"
        android:padding="6dp" android:layout_marginBottom="2dp">
        <Button android:id="@+id/btnStageAll" android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="+ Stage All" android:textSize="12sp"
            android:backgroundTint="@color/accent_green" android:textColor="@color/terminal_bg" android:layout_marginEnd="4dp"/>
        <Button android:id="@+id/btnUnstageAll" android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="− Unstage All" android:textSize="12sp"
            android:backgroundTint="@color/surface_medium" android:textColor="@color/text_primary" android:layout_marginStart="4dp"/>
    </LinearLayout>

    <!-- Commit input -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:background="@color/surface_dark"
        android:padding="6dp" android:layout_marginBottom="2dp">
        <EditText android:id="@+id/etCommitMsg" android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:hint="Commit message..." android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary" android:background="@null" android:fontFamily="monospace"
            android:textSize="13sp" android:paddingStart="4dp" android:imeOptions="actionDone" android:inputType="text" android:maxLines="1"/>
    </LinearLayout>

    <!-- Commit/Push buttons -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:padding="6dp" android:background="@color/surface_dark"
        android:layout_marginBottom="4dp">
        <Button android:id="@+id/btnCommit" android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="✓ Commit" android:textSize="12sp"
            android:backgroundTint="@color/accent_blue" android:textColor="@color/white" android:layout_marginEnd="3dp"/>
        <Button android:id="@+id/btnPull" android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="↓ Pull" android:textSize="12sp"
            android:backgroundTint="@color/surface_medium" android:textColor="@color/text_primary" android:layout_marginEnd="3dp"/>
        <Button android:id="@+id/btnPush" android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="↑ Push" android:textSize="12sp"
            android:backgroundTint="@color/accent_orange" android:textColor="@color/white" android:layout_marginEnd="3dp"/>
        <Button android:id="@+id/btnCommitPush" android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="✓↑" android:textSize="12sp"
            android:backgroundTint="@color/accent_green" android:textColor="@color/terminal_bg"/>
    </LinearLayout>

    <!-- Output log -->
    <ScrollView android:id="@+id/scrollLog" android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="2" android:padding="8dp">
        <TextView android:id="@+id/tvLog" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textColor="@color/terminal_text" android:textSize="12sp" android:fontFamily="monospace"
            android:lineSpacingExtra="2dp" android:textIsSelectable="true" android:text=""/>
    </ScrollView>

    <!-- Diff panel -->
    <ScrollView android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:padding="8dp">
        <TextView android:id="@+id/tvDiff" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:textColor="@color/accent_green" android:textSize="11sp" android:fontFamily="monospace"
            android:textIsSelectable="true" android:visibility="gone"/>
    </ScrollView>

</LinearLayout>
