<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/terminal_bg">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/surface_dark"
            app:titleTextColor="@color/accent_cyan"/>
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="12dp">

            <!-- Editor Settings -->
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="CODE EDITOR" android:textColor="@color/text_secondary"
                android:textSize="11sp" android:fontFamily="monospace" android:letterSpacing="0.1"
                android:paddingBottom="6dp" android:paddingTop="4dp"/>

            <androidx.cardview.widget.CardView app:cardBackgroundColor="@color/surface_dark"
                app:cardCornerRadius="8dp" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginBottom="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="12dp">

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginBottom="8dp">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Color Theme" android:textColor="@color/text_primary" android:textSize="13sp"/>
                        </LinearLayout>
                        <Spinner android:id="@+id/spinnerTheme" android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:backgroundTint="@color/accent_blue"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginBottom="8dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                            android:text="Font Size" android:textColor="@color/text_primary" android:textSize="13sp"/>
                        <EditText android:id="@+id/etFontSize" android:layout_width="60dp" android:layout_height="wrap_content"
                            android:inputType="number" android:textColor="@color/text_primary" android:background="@null"
                            android:textSize="13sp" android:gravity="end"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginBottom="8dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                            android:text="Tab Size" android:textColor="@color/text_primary" android:textSize="13sp"/>
                        <EditText android:id="@+id/etTabSize" android:layout_width="60dp" android:layout_height="wrap_content"
                            android:inputType="number" android:textColor="@color/text_primary" android:background="@null"
                            android:textSize="13sp" android:gravity="end"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginBottom="8dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                            android:text="Minimap" android:textColor="@color/text_primary" android:textSize="13sp"/>
                        <androidx.appcompat.widget.SwitchCompat android:id="@+id/switchMonacoMinimap"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginBottom="8dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                            android:text="Word Wrap" android:textColor="@color/text_primary" android:textSize="13sp"/>
                        <androidx.appcompat.widget.SwitchCompat android:id="@+id/switchWordWrap"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                            android:text="Auto Save" android:textColor="@color/text_primary" android:textSize="13sp"/>
                        <androidx.appcompat.widget.SwitchCompat android:id="@+id/switchAutoSave"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>

                    <Button android:id="@+id/btnSaveEditor"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="Save Editor Settings" android:backgroundTint="@color/accent_blue"
                        android:textColor="@color/white" android:layout_marginTop="10dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- App Settings -->
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="APP" android:textColor="@color/text_secondary"
                android:textSize="11sp" android:fontFamily="monospace" android:paddingBottom="6dp"/>

            <androidx.cardview.widget.CardView app:cardBackgroundColor="@color/surface_dark"
                app:cardCornerRadius="8dp" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginBottom="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="12dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginBottom="8dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                            android:text="Sound Effects" android:textColor="@color/text_primary" android:textSize="13sp"/>
                        <androidx.appcompat.widget.SwitchCompat android:id="@+id/switchSound"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginBottom="8dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                            android:text="Dark Mode" android:textColor="@color/text_primary" android:textSize="13sp"/>
                        <androidx.appcompat.widget.SwitchCompat android:id="@+id/switchDarkMode"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginBottom="8dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                            android:text="Default Folder" android:textColor="@color/text_primary" android:textSize="13sp"/>
                        <EditText android:id="@+id/etDefaultDir" android:layout_width="140dp" android:layout_height="wrap_content"
                            android:textColor="@color/text_primary" android:background="@null" android:textSize="12sp"
                            android:gravity="end" android:fontFamily="monospace"/>
                    </LinearLayout>
                    <Button android:id="@+id/btnSaveDir" android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:text="Save App Settings"
                        android:backgroundTint="@color/accent_green" android:textColor="@color/terminal_bg"
                        android:layout_marginBottom="6dp"/>
                    <Button android:id="@+id/btnClearCache" android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:text="Clear Cache"
                        android:backgroundTint="@color/surface_medium" android:textColor="@color/accent_red"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- GitHub Settings -->
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="GITHUB" android:textColor="@color/text_secondary"
                android:textSize="11sp" android:fontFamily="monospace" android:paddingBottom="6dp"/>

            <androidx.cardview.widget.CardView app:cardBackgroundColor="@color/surface_dark"
                app:cardCornerRadius="8dp" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginBottom="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="12dp">
                    <EditText android:id="@+id/etGithubToken" android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:hint="Personal Access Token"
                        android:textColor="@color/text_primary" android:textColorHint="@color/text_secondary"
                        android:background="@null" android:textSize="12sp" android:fontFamily="monospace"
                        android:inputType="textPassword" android:layout_marginBottom="8dp"/>
                    <EditText android:id="@+id/etGithubOwner" android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:hint="GitHub username / org"
                        android:textColor="@color/text_primary" android:textColorHint="@color/text_secondary"
                        android:background="@null" android:textSize="13sp" android:layout_marginBottom="8dp"/>
                    <EditText android:id="@+id/etGithubRepo" android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:hint="Repository name"
                        android:textColor="@color/text_primary" android:textColorHint="@color/text_secondary"
                        android:background="@null" android:textSize="13sp" android:layout_marginBottom="8dp"/>
                    <Button android:id="@+id/btnSaveGithub" android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:text="Save GitHub Settings"
                        android:backgroundTint="@color/accent_purple" android:textColor="@color/white"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Quick Links -->
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="QUICK LINKS" android:textColor="@color/text_secondary"
                android:textSize="11sp" android:fontFamily="monospace" android:paddingBottom="6dp"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="12dp">
                <Button android:id="@+id/btnOpenIde" android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="IDE" android:backgroundTint="@color/accent_blue"
                    android:textColor="@color/white" android:layout_marginEnd="4dp"/>
                <Button android:id="@+id/btnOpenGit" android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Git" android:backgroundTint="@color/accent_orange"
                    android:textColor="@color/white" android:layout_marginEnd="4dp"/>
                <Button android:id="@+id/btnOpenWorkflow" android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Workflows" android:backgroundTint="@color/accent_purple"
                    android:textColor="@color/white"/>
            </LinearLayout>

            <TextView android:id="@+id/tvVersion" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:textColor="@color/text_secondary"
                android:textSize="10sp" android:gravity="center" android:fontFamily="monospace"
                android:layout_marginTop="8dp"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
